{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2015",
    "lib": ["es2019", "dom"],
    "types": ["node", "jest"],
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
